// server/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Vocabulary {
  id         Int      @id @default(autoincrement())
  hebrew     String
  persian    String
  example    String?
  difficulty String?
  createdAt  DateTime @default(now())
}